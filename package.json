{
  "name": "tubegrab",
  "version": "1.0.0",
  "bin": "server.js",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "build": "electron-builder",
    "build:exe": "pkg . --targets node18-win-x64 --output dist/TubeGrab.exe"
  },
  "pkg": {
    "assets": [
      "public/**/*",
      "yt-dlp.exe",
      "node_modules/ffmpeg-static/**/*"
    ],
    "scripts": [
      "server.js"
    ]
  },
  "build": {
    "appId": "com.tubegrab.app",
    "productName": "TubeGrab Pro",
    "win": {
      "target": "portable"
    },
    "cscLink": null,
    "files": [
      "**/*",
      "!dist/*",
      "!node_modules/electron/**/*",
      "!node_modules/electron-builder/**/*"
    ],
    "extraResources": [
      "yt-dlp.exe"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "description": "",
  "dependencies": {
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "node-fetch": "^2.7.0",
    "yt-dlp-wrap-extended": "^2.3.15"
  },
  "devDependencies": {
    "electron": "^34.3.0",
    "electron-builder": "^25.1.8",
    "open": "^11.0.0",
    "pkg": "^5.8.1"
  }
}
